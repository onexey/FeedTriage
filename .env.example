# Copy to .env only if you prefer file-based config instead of direct environment variables.
# Non-secret defaults are built into the application except for focus topics, which stay user-defined.

# ── Required values ─────────────────────────────────────────────────────────
FEEDTRIAGE__FILTERING__FOCUS_TOPICS=
FEEDTRIAGE__MINIFLUX__API_TOKEN=
FEEDTRIAGE__AI__PROVIDERS__SCREEN_OLLAMA_SMALL__API_KEY=
FEEDTRIAGE__AI__PROVIDERS__REVIEW_OLLAMA_LARGE__API_KEY=

# ── Optional overrides ─────────────────────────────────────────────────────
# Uncomment only when you want behavior different from the built-in defaults.
# FEEDTRIAGE__MINIFLUX__BASE_URL=http://miniflux:8080
# FEEDTRIAGE__FILTERING__ANTI_TOPICS=
# FEEDTRIAGE__SCHEDULER__RUN_INTERVAL=0.00:05:00
# FEEDTRIAGE__PROCESSING__MAX_ARTICLES_PER_RUN=5
# FEEDTRIAGE__PROCESSING__DRY_RUN=false
# FEEDTRIAGE__PROCESSING__MAX_RETRIES_PER_ENTRY=5
# FEEDTRIAGE__STATE__FILE_PATH=./data/state.json
# FEEDTRIAGE__AI__SCREENING_CHAIN=screen_ollama_small
# FEEDTRIAGE__AI__REVIEW_CHAIN=review_ollama_large
# FEEDTRIAGE__AI__PROVIDERS__SCREEN_OLLAMA_SMALL__MODEL=ministral-3:3b
# FEEDTRIAGE__AI__PROVIDERS__SCREEN_OLLAMA_SMALL__TIMEOUT_SECONDS=60
# FEEDTRIAGE__AI__PROVIDERS__REVIEW_OLLAMA_LARGE__MODEL=gemma3:27b
# FEEDTRIAGE__AI__PROVIDERS__REVIEW_OLLAMA_LARGE__TIMEOUT_SECONDS=180
