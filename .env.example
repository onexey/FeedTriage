# ── Scheduler ──────────────────────────────────────────────────────────────
# Run a processing pass immediately when the container starts
FEEDTRIAGE__SCHEDULER__RUN_ON_START=true
# How often to repeat. Format: [d.]hh:mm:ss  (e.g. 1.00:00:00 = every 24h)
FEEDTRIAGE__SCHEDULER__RUN_INTERVAL=1.00:00:00

# ── Miniflux ───────────────────────────────────────────────────────────────
FEEDTRIAGE__MINIFLUX__BASE_URL=http://miniflux:8080
FEEDTRIAGE__MINIFLUX__API_TOKEN=

# ── Filtering ──────────────────────────────────────────────────────────────
# Required: comma-separated list of topics the AI should consider relevant
FEEDTRIAGE__FILTERING__FOCUS_TOPICS=software engineering,software architecture,team leadership
# Optional: comma-separated topics to actively filter out (reduces false positives)
FEEDTRIAGE__FILTERING__ANTI_TOPICS=

# ── Processing ─────────────────────────────────────────────────────────────
# Limit articles per run (leave empty for unlimited; useful for testing)
FEEDTRIAGE__PROCESSING__MAX_ARTICLES_PER_RUN=
# Dry run: evaluate articles but never mark entries as read
FEEDTRIAGE__PROCESSING__DRY_RUN=false

# ── State ──────────────────────────────────────────────────────────────────
# Path to the JSON file that tracks the newest processed publication time across restarts.
# Relative paths are resolved from the working directory (default: next to the binary).
# Mount this path to a persistent volume when running in Docker.
FEEDTRIAGE__STATE__FILE_PATH=./data/state.json

# ── AI chains ──────────────────────────────────────────────────────────────
# Comma-separated ordered list of provider instance names for Stage 1 and Stage 2.
# The first provider that returns a valid response wins; the rest are fallbacks.
FEEDTRIAGE__AI__SCREENING_CHAIN=screen_ollama_small
FEEDTRIAGE__AI__REVIEW_CHAIN=review_ollama_large

# ── AI provider instances (Ollama Cloud) ──────────────────────────────────
# API keys are available at https://ollama.com/settings/api-keys
#
# Stage 1: fast, small model for rapid screening
FEEDTRIAGE__AI__PROVIDERS__SCREEN_OLLAMA_SMALL__TYPE=ollama
FEEDTRIAGE__AI__PROVIDERS__SCREEN_OLLAMA_SMALL__BASE_URL=https://ollama.com/api
FEEDTRIAGE__AI__PROVIDERS__SCREEN_OLLAMA_SMALL__MODEL=qwen3:4b
FEEDTRIAGE__AI__PROVIDERS__SCREEN_OLLAMA_SMALL__API_KEY=
FEEDTRIAGE__AI__PROVIDERS__SCREEN_OLLAMA_SMALL__TIMEOUT_SECONDS=60

# Stage 2: larger model for thorough review
FEEDTRIAGE__AI__PROVIDERS__REVIEW_OLLAMA_LARGE__TYPE=ollama
FEEDTRIAGE__AI__PROVIDERS__REVIEW_OLLAMA_LARGE__BASE_URL=https://ollama.com/api
FEEDTRIAGE__AI__PROVIDERS__REVIEW_OLLAMA_LARGE__MODEL=qwen3:14b
FEEDTRIAGE__AI__PROVIDERS__REVIEW_OLLAMA_LARGE__API_KEY=
FEEDTRIAGE__AI__PROVIDERS__REVIEW_OLLAMA_LARGE__TIMEOUT_SECONDS=180

# ── Example: adding a second fallback provider ─────────────────────────────
# FEEDTRIAGE__AI__SCREENING_CHAIN=screen_ollama_small,screen_ollama_fallback
# FEEDTRIAGE__AI__PROVIDERS__SCREEN_OLLAMA_FALLBACK__TYPE=ollama
# FEEDTRIAGE__AI__PROVIDERS__SCREEN_OLLAMA_FALLBACK__BASE_URL=https://ollama.com/api
# FEEDTRIAGE__AI__PROVIDERS__SCREEN_OLLAMA_FALLBACK__MODEL=llama3.1:8b
# FEEDTRIAGE__AI__PROVIDERS__SCREEN_OLLAMA_FALLBACK__API_KEY=
# FEEDTRIAGE__AI__PROVIDERS__SCREEN_OLLAMA_FALLBACK__TIMEOUT_SECONDS=60
